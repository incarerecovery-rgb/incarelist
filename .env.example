# Copy this file to .env.local and fill in real values.
# The app runs fine on mock data (lib/mock-data.ts) without these set.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed into /admin/claims
ADMIN_EMAILS=

# Optional — email notifications for new claims/submissions via resend.com.
# Leave blank and notifications are silently skipped (the admin queues in
# the app still work fine either way).
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=

# Powers the Google Maps embed on Premium provider profiles (Maps Embed
# API, restricted to your domain — see README for setup). Public/client-
# exposed by design (NEXT_PUBLIC_), same as any Maps embed key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). Leave blank
# and analytics is silently skipped — no code changes needed once you add
# a real value here.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
